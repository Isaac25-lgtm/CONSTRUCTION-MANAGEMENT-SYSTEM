# BuildPro Environment Configuration
# Copy to .env for local dev. For Render, set these in the dashboard.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_SETTINGS_MODULE=buildpro.settings.development
DJANGO_DEBUG=True

# Database -- local dev (individual fields)
POSTGRES_DB=buildpro
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-local-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Production (Neon) -- use DATABASE_URL instead of individual fields:
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Redis / Celery broker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# On Render: auto-wired from Key Value service via render.yaml

# AI
AI_PROVIDER=gemini
AI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=your-gemini-api-key-here

# File Storage -- production only (Cloudflare R2 / S3-compatible)
# AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=buildpro

# Observability -- production only
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Production only
# ALLOWED_HOSTS=buildpro-web.onrender.com,yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://buildpro-web.onrender.com,https://yourdomain.com
# CORS_ALLOWED_ORIGINS=  (not needed if same-origin)
